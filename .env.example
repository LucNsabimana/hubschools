# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub

# Google OAuth Client ID
# Get this from: console.cloud.google.com > APIs & Services > Credentials
REACT_APP_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# Google Sheets API Key
# Get this from: console.cloud.google.com > APIs & Services > Credentials > API Key
REACT_APP_SHEETS_API_KEY=YOUR_SHEETS_API_KEY_HERE

# Your master Google Sheet ID
# This is the long string in the URL when you open your Google Sheet:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
REACT_APP_SHEET_ID=YOUR_SHEET_ID_HERE
